#!/usr/bin/env bash
#
# transcribe — transcribe audio/video via ElevenLabs Scribe (diarized).
# Self-contained: copy this file and set your own ELEVENLABS_API_KEY.

set -eo pipefail

PROG=${0##*/}
msg() { printf '  %s\n' "$1" >&2; }
err() { printf '%s: %s\n' "$PROG" "$1" >&2; }
die() { err "$1"; exit "${2:-1}"; }

usage() {
  cat >&2 <<'EOF'
transcribe — transcribe audio/video via ElevenLabs Scribe (diarized)

Usage:
  transcribe [options] <file|host:path>

Options:
  -l, --lang <code>      language (default: pt; an ISO code, or "auto" to detect)
  -o, --out <dir>        parent dir for the output subfolder (default: file's dir; CWD if remote)
  -k, --keyterms <list>  comma-separated terms/names to boost accuracy ("Gauss,Kleverson")
  -s, --speakers <n>     expected number of speakers (improves diarization)
      --open             open the output folder when done
  -h, --help

Examples:
  transcribe meeting.mp4
  transcribe note.m4a
  transcribe macmini:~/Downloads/call.webm          # remote file, streamed over SSH
  transcribe call.mp4 -l en
  transcribe sales.mp4 -k "Acme,Gauss" -s 4 --open

Output: creates the subfolder <name>.transcript/ containing
  <name>.md     diarized, with timestamps
  <name>.txt    plain text
  <name>.json   raw ElevenLabs response

Requirements:
  ELEVENLABS_API_KEY in the environment OR in ~/.config/transcribe/env
  jq        (brew install jq)
  ffmpeg    (brew install ffmpeg) — only for video / large audio
EOF
}

OUTBASE=""; LANG_CODE="pt"; KEYTERMS=""; SPEAKERS=""; OPEN=false
positional=()
while [ $# -gt 0 ]; do
  case "$1" in
    -h | --help) usage; exit 0 ;;
    -l | --lang) [ -n "${2:-}" ] || die "-l requires a language code"; LANG_CODE="$2"; shift 2 ;;
    -l=* | --lang=*) LANG_CODE="${1#*=}"; shift ;;
    -o | --out) [ -n "${2:-}" ] || die "-o requires a directory"; OUTBASE="$2"; shift 2 ;;
    -o=* | --out=*) OUTBASE="${1#*=}"; shift ;;
    -k | --keyterms) [ -n "${2:-}" ] || die "-k requires a list of terms"; KEYTERMS="$2"; shift 2 ;;
    -k=* | --keyterms=*) KEYTERMS="${1#*=}"; shift ;;
    -s | --speakers) [ -n "${2:-}" ] || die "-s requires a number"; SPEAKERS="$2"; shift 2 ;;
    -s=* | --speakers=*) SPEAKERS="${1#*=}"; shift ;;
    --open) OPEN=true; shift ;;
    --) shift; while [ $# -gt 0 ]; do positional+=("$1"); shift; done ;;
    -*) die "unknown option: $1 (see --help)" ;;
    *) positional+=("$1"); shift ;;
  esac
done
set -- "${positional[@]}"
[ $# -ge 1 ] || { usage; exit 1; }
INPUT="$1"

# --- API key: env var, else ~/.config/transcribe/env ---
if [ -z "${ELEVENLABS_API_KEY:-}" ] && [ -f "$HOME/.config/transcribe/env" ]; then
  ELEVENLABS_API_KEY=$(grep -m1 '^ELEVENLABS_API_KEY=' "$HOME/.config/transcribe/env" |
    cut -d= -f2- | tr -d "\"' \t\r\n")
fi
[ -n "${ELEVENLABS_API_KEY:-}" ] || die \
  "ELEVENLABS_API_KEY is not set. Export it (export ELEVENLABS_API_KEY=sk_...) or create ~/.config/transcribe/env with a line ELEVENLABS_API_KEY=sk_..."

command -v curl >/dev/null || die "curl not found"
command -v jq >/dev/null || die "jq not found — install: brew install jq"

WORK=$(mktemp -d "${TMPDIR:-/tmp}/transcribe.XXXXXX")
trap 'rm -rf "$WORK"' EXIT

# --- local vs remote (host:path, scp style) ---
REMOTE=""; RPATH=""
if [ ! -e "$INPUT" ] && [[ "$INPUT" == *:* ]] && [[ "$INPUT" != /* ]]; then
  REMOTE="${INPUT%%:*}"; RPATH="${INPUT#*:}"
  BASE="${RPATH##*/}"; SRCDIR="$PWD"
elif [ -e "$INPUT" ]; then
  BASE="${INPUT##*/}"; SRCDIR=$(cd "$(dirname "$INPUT")" && pwd)
else
  die "'$INPUT' does not exist (and is not a host:path)"
fi
STEM="${BASE%.*}"; EXT="${BASE##*.}"

# Output always goes into a subfolder <stem>.transcript/ (parent = -o, else the
# source file's dir; CWD when the file is remote).
OUTDIR="${OUTBASE:-$SRCDIR}/$STEM.transcript"

# --- get the audio to upload ---
# Video / large audio / remote -> extract & compress to mono Opus with ffmpeg.
# Small local audio -> upload the original directly (no ffmpeg).
UPLOAD=""; UPLOAD_NAME=""
if [ -n "$REMOTE" ]; then
  command -v ffmpeg >/dev/null || die "ffmpeg is required for remote files — install: brew install ffmpeg"
  command -v ssh >/dev/null || die "ssh not found"
  msg "streaming from $REMOTE over SSH + extracting audio..."
  ssh "$REMOTE" "cat \"$RPATH\"" |
    ffmpeg -hide_banner -loglevel error -err_detect ignore_err -y -i pipe:0 -vn -ac 1 -c:a libopus -b:a 48k "$WORK/audio.opus"
  UPLOAD="$WORK/audio.opus"; UPLOAD_NAME="audio.opus"
else
  is_video=false
  if command -v ffprobe >/dev/null; then
    [ -n "$(ffprobe -v error -select_streams v -show_entries stream=codec_type -of csv=p=0 "$INPUT" 2>/dev/null)" ] && is_video=true
  else
    case "$EXT" in
      mp4 | mov | mkv | webm | avi | m4v | flv | wmv | mpg | mpeg | 3gp | MP4 | MOV | MKV | WEBM | AVI | M4V | MPG) is_video=true ;;
    esac
  fi
  size=$(stat -f%z "$INPUT" 2>/dev/null || echo 0)
  if $is_video || [ "$size" -gt 104857600 ]; then
    command -v ffmpeg >/dev/null || die "ffmpeg is required for video/large audio — install: brew install ffmpeg"
    msg "extracting audio with ffmpeg..."
    # -nostdin: don't consume the terminal's stdin (avoids ffmpeg exiting non-zero
    #   in some interactive shells). -err_detect ignore_err: tolerate a corrupt/
    #   truncated tail (common in interrupted recordings) instead of aborting.
    ffmpeg -nostdin -hide_banner -loglevel error -err_detect ignore_err -y -i "$INPUT" -vn -ac 1 -c:a libopus -b:a 48k "$WORK/audio.opus"
    UPLOAD="$WORK/audio.opus"; UPLOAD_NAME="audio.opus"
  else
    UPLOAD="$INPUT"; UPLOAD_NAME="audio.$EXT"
  fi
fi

# --- build the request ---
form=(-F model_id=scribe_v2 -F diarize=true)
[ "$LANG_CODE" != "auto" ] && form+=(-F "language_code=$LANG_CODE")
[ -n "$SPEAKERS" ] && form+=(-F "num_speakers=$SPEAKERS")
if [ -n "$KEYTERMS" ]; then
  IFS=',' read -ra _terms <<<"$KEYTERMS" || true
  for t in "${_terms[@]}"; do
    t=$(printf '%s' "$t" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    [ -n "$t" ] && form+=(-F "keyterms[]=$t")
  done
fi

# --- transcribe ---
msg "transcribing via ElevenLabs scribe_v2 (language: $LANG_CODE)..."
code=$(curl -sS -X POST https://api.elevenlabs.io/v1/speech-to-text \
  -H "xi-api-key: $ELEVENLABS_API_KEY" \
  -F "file=@$UPLOAD;filename=$UPLOAD_NAME" \
  "${form[@]}" \
  -w '%{http_code}' -o "$WORK/transcript.json" --max-time 1800 || true)
[ "$code" = "200" ] || die "ElevenLabs returned HTTP ${code:-?}: $(head -c 300 "$WORK/transcript.json" 2>/dev/null)"

# --- output ---
mkdir -p "$OUTDIR" || die "could not create output folder: $OUTDIR"
OUTDIR=$(cd "$OUTDIR" && pwd)
MD="$OUTDIR/$STEM.md"
TXT="$OUTDIR/$STEM.txt"
JSON="$OUTDIR/$STEM.json"
cp "$WORK/transcript.json" "$JSON"
jq -r '.text' "$WORK/transcript.json" >"$TXT"

# Diarized markdown: group words by speaker (new block on speaker change or a
# gap > 2s), map speaker_id -> "Speaker N" by order of appearance.
jq -r --arg title "$STEM" '
  def hms(s): (s|floor) as $t
    | [($t/3600|floor), (($t%3600)/60|floor), ($t%60)]
    | map(tostring | if length < 2 then "0" + . else . end) | join(":");
  [.words[] | select(.type == "word")] as $w
  | ($w | reduce .[] as $x ([];
      (($x.speaker_id // "speaker_0")) as $spk
      | (if length > 0 then .[-1] else null end) as $cur
      | if $cur == null or $cur.speaker != $spk or ($x.start - $cur.end) > 2
        then . + [{speaker: $spk, start: $x.start, end: $x.end, text: $x.text}]
        else .[0:-1] + [$cur + {end: $x.end,
              text: ($cur.text + (if ($x.text | test("^[.,!?;:]")) then "" else " " end) + $x.text)}]
        end)) as $segs
  | ([$segs[].speaker] | reduce .[] as $s ({m: {}, n: 0};
        if .m[$s] then . else {m: (.m + {($s): (.n + 1)}), n: (.n + 1)} end)).m as $labels
  | ($w | if length > 0 then .[-1].end else 0 end) as $dur
  | "# Transcript — \($title)\n",
    "- **Duration:** \(hms($dur))",
    "- **Language:** \(.language_code // "n/a")\(if .language_probability then " (\((.language_probability * 100) | floor)%)" else "" end)",
    "- **Speakers detected:** \($labels | length)",
    "- **Model:** scribe_v2 (ElevenLabs) · diarization on\n",
    "---\n",
    ($segs[] | "**Speaker \($labels[.speaker])** `[\(hms(.start))]`\n\n\(.text | ltrimstr(" "))\n")
  ' "$WORK/transcript.json" >"$MD"

# --- summary ---
read -r dur nspk nwords < <(jq -r '
  [.words[] | select(.type == "word")] as $w
  | "\(($w | if length > 0 then .[-1].end else 0 end) | floor) \([$w[] | .speaker_id // "speaker_0"] | unique | length) \($w | length)"
  ' "$WORK/transcript.json") || true
printf '\n\342\234\205 %s\n' "$BASE" >&2
printf '   ~%dm%02ds \302\267 %s speaker(s) \302\267 %s words\n' "$((dur / 60))" "$((dur % 60))" "$nspk" "$nwords" >&2
printf '   %s\n   %s\n   %s\n' "$MD" "$TXT" "$JSON" >&2

$OPEN && command -v open >/dev/null && open "$OUTDIR" || true
